# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=24h

# Server
NODE_ENV=production
BACKEND_PORT=5000
FRONTEND_PORT=3000

# File Upload
MAX_FILE_SIZE=10MB
UPLOAD_DIR=uploads
