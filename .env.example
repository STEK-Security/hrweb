POSTGRES_USER=yourusername
POSTGRES_PASSWORD=yourstrongpassword
POSTGRES_DB=performancereviewdb
DB_HOST=postgres
DB_PORT=5432 # Exposed on host, used by backend to connect to postgres container

BACKEND_PORT=5000 # Exposed on host, used by frontend to connect to backend

# Frontend port (host port mapped to Nginx container's port 80)
FRONTEND_PORT=3000

# SHAREPOINT_BASE_URL=your_sharepoint_site_url

# Email Configuration (leave blank or use Ethereal for local dev if not set up)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false # Use true for port 465, false for others (like 587)
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
NODE_ENV=development # Set to 'production' in actual deployment. Used by backend/emailService.js and backend/Dockerfile.
